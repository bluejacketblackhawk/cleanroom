# --- Node / frontend ---
node_modules/
apps/desktop/dist/
apps/desktop/dist-ssr/
*.local
.vite/

# --- Tauri generated ---
apps/desktop/src-tauri/gen/

# --- Python (eval harness, dev-only) ---
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# --- Models, sidecars & large binaries (shipped via GH Releases, hash-manifested) ---
/models/
/vendor/
*.onnx
*.gguf
